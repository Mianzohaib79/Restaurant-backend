# Port for local development
PORT=8000

# Database Connection (Provide EITHER MONGODB_URI OR MONGODB_USERNAME/MONGODB_PASSWORD)
# Option 1: Standard MongoDB connection string (highly recommended for Vercel/Atlas integrations)
MONGODB_URI=your_mongodb_connection_uri

# Option 2: Individual Atlas credentials
MONGODB_USERNAME=your_mongodb_username
MONGODB_PASSWORD=your_mongodb_password

# Authentication
JWT_SECRET=your_jwt_secret

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend App URL (for CORS allowance)
FRONTEND_URL=https://restaurant-app-murex-nine.vercel.app
